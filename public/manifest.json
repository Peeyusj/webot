{
  "manifest_version": 3,
  "name": "WebChat - Talk to any webpage",
  "version": "1.0.0",
  "description": "Turn any documentation or article into an interactive AI assistant.",
  "permissions": ["activeTab", "scripting", "storage", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Toggle WebChat"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
